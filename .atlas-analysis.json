  "keyFeatures": [
    "Push-to-talk voice-to-text transcription",
    "7 transcription engines (Whisper, Parakeet, Moonshine, SenseVoice, Paraformer, Dolphin, Omnilingual)",
    "GPU acceleration (Vulkan, CUDA, ROCm)",
    "Meeting mode with continuous transcription and speaker attribution",
    "Wayland compositor integration (Hyprland, Sway, River)",
    "Multiple output modes (keyboard typing, clipboard, paste)",
    "Offline-first operation with optional remote server support",
    "Audio feedback with customizable themes",
    "Text post-processing with LLM integration",
    "Waybar/status bar integration"
  ],
  "publicApiSurface": [
    "voxtype daemon",
    "voxtype record start/stop/toggle/cancel",
    "voxtype transcribe <file>",
    "voxtype setup [action]",
    "voxtype config",
    "voxtype status",
    "voxtype meeting start/stop/pause/resume",
    "voxtype meeting export",
    "voxtype meeting list"
  ]
